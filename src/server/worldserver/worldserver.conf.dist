###################################################################################################

###################################################################################################
###################################################################################################
#                                                                                                 #
#                              SERVER TECHNICAL CONFIGURATION                                 #
#                                                                                                 #
###################################################################################################
###################################################################################################

###################################################################################################
# NETWORK CONFIGURATION
#
#    Network.Threads
#        Number of network threads.
#        Recommendation: 1 thread per 1000 connections.
#        Default: 1

Network.Threads = 1

#
#    Network.OutKBuff
#        Taille (en octets) of tampon of sortie of noyau (SO_SNDBUF).
#        Default: -1 - (Use the system default value)

Network.OutKBuff = -1

#
#    Network.OutUBuff
#        Taille (en octets) of tampon of sortie en space utilisateur, per connection.
#        Default: 65536

Network.OutUBuff = 65536

#
#    Network.TcpNodelay
#        Controle the algorithme of Nagle (TCP).
#        Default: 0 - (Enabled, moins of trafic, plus of latence)
#                 1 - (Disabled, plus of trafic, moins of latence, TCP_NO_DELAY)

Network.TcpNodelay = 1

#
###################################################################################################

###################################################################################################
# CONSOLE AND REMOTE ACCESS
#
#    Console.Enable
#        Enabled la console of commandes of server.
#        Default: 1 - (Enabled)
#                 0 - (Disabled)

Console.Enable = 1

#
#    Ra.Enable
#        Enabled la console distante via telnet.
#        Default: 0 - (Disabled)
#                 1 - (Enabled)

Ra.Enable = 0

#
#    Ra.IP
#        Address IP of ecoute of the acces distant.
#        Default: "0.0.0.0" - (All the interfaces)

Ra.IP = "0.0.0.0"

#
#    Ra.Port
#        Port TCP of the console distante.
#        Default: 3443

Ra.Port = 3443

#
#    Ra.MinLevel
#        Security level minimum for use la console distante.
#        Default: 3 - (Administrateur)

Ra.MinLevel = 3

#
#    SOAP.Enabled
#        Enabled le service SOAP (API web for commandes distantes).
#        Default: 0 - (Disabled)
#                 1 - (Enabled)

SOAP.Enabled = 0

#
#    SOAP.IP
#        Address IP of ecoute of service SOAP.
#        Default: "127.0.0.1" - (Localhost only)

SOAP.IP = "127.0.0.1"

#
#    SOAP.Port
#        Port TCP of service SOAP.
#        Default: 7878

SOAP.Port = 7878

#
###################################################################################################

###################################################################################################
# PERFORMANCE
#
#    UseProcessors
#        Masque of processeurs for systemes multi-processeurs (Windows).
#        Default: 0 - (Selection by the system)

UseProcessors = 0

#
#    ProcessPriority
#        Priorite of processus server.
#        Linux : value nice of -15 (requires root).
#        Windows : processus en classe HIGH.
#        Default: 0 - (Normale)
#                 1 - (Haute)

ProcessPriority = 0

#
#    Compression
#        Level of compression the paquets sent to the client.
#        Range: 1-9
#        Default: 1 - (Rapide)
#                 9 - (Meilleure compression)

Compression = 1

#
#    SaveRespawnTimeImmediately
#        Save le temps of reapparition the creatures a their death
#        and the game objects a their utilisation.
#        Default: 1 - (Enabled, save immediate)
#                 0 - (Disabled, save to the dechargement of the grille)

SaveRespawnTimeImmediately = 1

#
#    MaxOverspeedPings
#        Maximum pings of sur-speed before disconnection of player.
#        Default: 0  - (Disabled)
#                 2  - (Enabled, minimum)
#                 3+ - (Enabled, plus tolerant)

MaxOverspeedPings = 0

#
#    GridUnload
#        Dechargement the grilles of the map for economiser la memoire.
#        Disable if suffisamment of RAM is available for accelerer
#        the transitions of zone the players.
#        Default: 1 - (Enabled)
#                 0 - (Disabled)

GridUnload = 1

#
#    SocketTimeOutTime
#        Delai (in milliseconds) before disconnection of a session inactive
#        on the ecran of selection of character.
#        Default: 900000 - (15 minutes)

SocketTimeOutTime = 900000

#
#    SessionAddDelay
#        Delai (in microseconds) after the authentification before the ajout
#        of the connection a la session world. Evite the problemes of concurrence.
#        Default: 10000 - (10 millisecondes)

SessionAddDelay = 10000

#
#    GridCleanUpDelay
#        Delai (in milliseconds) before le nettoyage the grilles inactives.
#        Default: 300000 - (5 minutes)

GridCleanUpDelay = 300000

#
#    MapUpdateInterval
#        Interval (in milliseconds) between chaque update a day the maps.
#        C'est le "tick" principal of server world.
#        Default: 100 - (0.1 second)

MapUpdateInterval = 100

#
#    ChangeWeatherInterval
#        Interval (in milliseconds) between the updates a day of the meteo.
#        Default: 600000 - (10 minutes)

ChangeWeatherInterval = 600000

#
#    PlayerSaveInterval
#        Interval (in milliseconds) between the saves automatiques the players.
#        Default: 90000 - (90 seconds)

PlayerSaveInterval = 90000

#
#    mmap.enablePathFinding
#        Enabled the pathfinding by MMAPs (navmesh).
#        Recommande for a deplacement intelligent the creatures.
#        Default: 0 - (Disabled)
#                 1 - (Enabled)

mmap.enablePathFinding = 1

#
#    vmap.enableLOS
#    vmap.enableHeight
#        Support VMap for la line of vue (LOS) and le calcul of hauteur.
#        Indispensable for le comportement correct the creatures and the sorts.
#        Default: 1 - (Enabled)
#                 0 - (Disabled)

vmap.enableLOS    = 1
vmap.enableHeight = 1

#
#    vmap.petLOS
#        Check of the line of vue for the pets,
#        emfishing the attaques a travers the murs.
#        Default: 1 - (Enabled)
#                 0 - (Disabled, moins of charge CPU)

vmap.petLOS = 1

#
#    vmap.enableIndoorCheck
#        Detection interieur/exterieur basee on the VMaps.
#        Removed the auras exclusives a the exterieur (mounts, etc.) en interieur.
#        Default: 1 - (Enabled)
#                 0 - (Disabled, moins of charge CPU)

vmap.enableIndoorCheck = 1

#
#    DetectPosCollision
#        Check the collisions for the positions finales of deplacement,
#        invocations, etc. with the items and the murs (si vmaps enabled).
#        Default: 1 - (Enabled)
#                 0 - (Disabled, moins precis but moins of charge CPU)

DetectPosCollision = 1

#
#    TargetPosRecalculateRange
#        Distance maximum between le point cible of deplacement and the item cible
#        before recalcul of path.
#        Range:  0.5-5.0
#        Default: 1.5
#                 0.5 - (Contact, reaction sensible to the mouvement of the cible)
#                 5.0 - (Portee melee, moins of charge CPU)

TargetPosRecalculateRange = 1.5

#
#    UpdateUptimeInterval
#        Interval (in minutes) of update a day of temps of fonctionnement
#        of realm in la base auth.
#        Default: 10

UpdateUptimeInterval = 10

#
#    MaxCoreStuckTime
#        Duration (in seconds) before a crash force if le server is fige.
#        Default: 0   - (Disabled)
#                 10+ - (Enabled, recommande 10+)

MaxCoreStuckTime = 0

#
#    MaxMapStuckTime
#        Duration (in seconds) before le restart force of a map figee.
#        Default: 0   - (Disabled)
#                 10+ - (Enabled, recommande 10+)

MaxMapStuckTime = 0

#
#    AddonChannel
#        Enabled le canal of communication the addons via le server.
#        Certains addons ne fonctionneront pas without this canal.
#        Default: 1 - (Enabled)
#                 0 - (Disabled)

AddonChannel = 1

#
#    MapUpdate.Threads
#        Number of threads of update a day the maps.
#        Default: 1

MapUpdate.Threads = 1

#
#    CleanCharacterDB
#        Nettoie the hauts-faits, skills, sorts and talents obsoletes
#        of the base of data characters to the startup.
#        Default: 0 - (Disabled)
#                 1 - (Enabled)

CleanCharacterDB = 0

#
#    ResetCharacterDB
#        Removed TOUTES the data of characters, progressions of accounts,
#        guilds, courriers, auctions and data associees to the startup of server.
#        Utile after a phase of test PTR.
#        WARNING: This operation is irreversible ! Remettre a 0 after le reset.
#        Default: 0 - (Disabled)
#                 1 - (Enabled, removed tout to the prochain startup)

ResetCharacterDB = 0

#
#    PersistentCharacterCleanFlags
#        Determine quels flags of nettoyage restent actifs after a nettoyage.
#        Value en masque of bits (see /doc/CharacterDBCleanup.txt).
#        Example: 14 - (Skills + talents + sorts resteront actifs)
#        Default:  0  - (All the nettoyages disabled after execution)

PersistentCharacterCleanFlags = 0


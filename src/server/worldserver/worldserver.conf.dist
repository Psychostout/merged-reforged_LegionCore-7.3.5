#                 1 - (Enabled)

Warden.Enabled = 0

#
#    WardenExtended.Enabled
#        Enable the system anticheat etendu (checks additional).
#        Default: 0 - (Disabled)
#                 1 - (Enabled)

WardenExtended.Enabled = 0

#
#    Warden.BasicSecurityLevelReq
#        Security level en dessous duquel the checks of base are envoyees.
#        Default: 40

Warden.BasicSecurityLevelReq = 40

#
#    Warden.MaxSecurityLevelReq
#        Security level en dessous duquel the checks avancees are envoyees.
#        Default: 100

Warden.MaxSecurityLevelReq = 100

#
#    Warden.ClientResponseDelay
#        Delai (in milliseconds) before disconnection of client which ne repond pas.
#        Default: 60000 - (1 minute)

Warden.ClientResponseDelay = 60000

#
#    Warden.ClientCheckHoldOff
#        Delai (in milliseconds) between deux envois of checks to the client.
#        A value basse augmente le trafic and la charge on the client and le server.
#        Default: 25000 - (25 seconds)

Warden.ClientCheckHoldOff = 25000

#
###################################################################################################

###################################################################################################
# SQL UPDATES
#
#    Updates.EnableDatabases
#        Masque of bits the bases of data a mettre a day automatically.
#        DATABASE_LOGIN     = 1  (Base auth)
#        DATABASE_CHARACTER = 2  (Base characters)
#        DATABASE_WORLD     = 4  (Base world)
#        DATABASE_HOTFIX    = 8  (Base hotfixes)
#        Default: 15 - (All enabled)
#                 4  - (World only)
#                 0  - (All disabled)

Updates.EnableDatabases = 15

#
#    Updates.AutoSetup
#        Peuple automatically the bases of data empty to the first startup.
#        Default: 1 - (Enabled)
#                 0 - (Disabled)

Updates.AutoSetup = 1

#
#    Updates.Redundancy
#        Check the updates a day already appliquees by hash for detecter the modifications
#        and the reappliquer if required.
#        Default: 1 - (Enabled)
#                 0 - (Disabled)

Updates.Redundancy = 1

#
#    Updates.ArchivedRedundancy
#        Check the hash the updates a day archivees (ralentit le startup).
#        Default: 0 - (Disabled)
#                 1 - (Enabled)

Updates.ArchivedRedundancy = 0

#
#    Updates.AllowRehash
#        Insere le hash actuel of a file en base il is manquant.
#        Utile for marquer a file like applique without connaitre its hash.
#        Default: 1 - (Enabled)
#                 0 - (Disabled)

Updates.AllowRehash = 1

#
#    Updates.CleanDeadRefMaxCount
#        Nettoie the references orphelines if a update a day a ete renommee ou supprimee.
#        S'execute only if le number of references manquantes is inferieur ou egal
#        a this value (protection contre the effacement accidentel of the historique).
#        Default: 3  - (Enabled)
#                 0  - (Disabled)
#                -1  - (Enabled, illimite)

Updates.CleanDeadRefMaxCount = 3

#
###################################################################################################

###################################################################################################
# HOTSWAP (DYNAMIC SCRIPT RELOADING)
#
#    HotSwap.Enabled
#        Enabled le reload dynamique the scripts (requires DYNAMIC_LINKING=1 a la compilation).
#        Reload automatically the scripts modifies.
#        Default: 1 - (Enabled)
#                 0 - (Disabled)

HotSwap.Enabled = 1

#
#    HotSwap.ScriptDir
#        Directory contenant the bibliotheques of scripts (.dll/.so).
#        Default: "scripts"

HotSwap.ScriptDir = "scripts"

#
#    HotSwap.EnableReCompiler
#        Enabled le recompileur dynamique of scripts.
#        Surveille the directories sources and recompile the modules modifies.
#        Default: 0 - (Disabled)
#                 1 - (Enabled)

HotSwap.EnableReCompiler = 1

#
#    HotSwap.EnableEarlyTermination
#        Interrompt la compilation of a module if a file source associe
#        a ete modifie between-temps.
#        Default: 1 - (Enabled)

HotSwap.EnableEarlyTermination = 1

#
#    HotSwap.EnableBuildFileRecreation
#        Regenere the files of build quand the sources are ajoutees ou removed.
#        Default: 1 - (Enabled)

HotSwap.EnableBuildFileRecreation = 1

#
#    HotSwap.EnableInstall
#        Execute cmake install after the compilations automatiques.
#        Default: 1 - (Enabled)

HotSwap.EnableInstall = 1

#
#    HotSwap.EnablePrefixCorrection
#        Corrige automatically CMAKE_INSTALL_PREFIX to the emplacement
#        actuel of binaire in the system of files.
#        Default: 1 - (Enabled)

HotSwap.EnablePrefixCorrection = 1

#
#    HotSwap.ReCompilerBuildType
#        Type of build for the compilations automatiques.
#        Default: ""        - (Used le type natif of module)
#                 "Release" - (Release only)
#                 "Debug"   - (Debug only)

HotSwap.ReCompilerBuildType = ""

#
###################################################################################################

###################################################################################################
# LOG CONFIGURATION
#
#    LogDB.Opt.ClearInterval
#        Interval (in minutes) of timer of nettoyage of the table `logs`.
#        Default: 10

LogDB.Opt.ClearInterval = 10

#
#    LogDB.Opt.ClearTime
#        Duration (in seconds) of conservation the old entrees of the table `logs`.
#        Default: 1209600 - (14 days)
#                 0       - (Disabled, ne removed never)

LogDB.Opt.ClearTime = 1209600

#
#    PacketLogFile
#        File of log binaire the paquets network.
#        The extension must be .pkt for be lisible by WowPacketParser.
#        Example: "World.pkt"
#        Default:  ""  - (Disabled)

PacketLogFile = ""

#
#  Configuration the Appenders (destinations of log) :
#    Appender.name
#        Format: Type,NivwaterLog,Flags,optionnel1,optionnel2,optionnel3
#
#        Type :
#            0 - None
#            1 - Console
#            2 - File
#            3 - Base of data
#
#        NivwaterLog :
#            0 - Disabled
#            1 - Trace
#            2 - Debug
#            3 - Info
#            4 - Warn (Warning)
#            5 - Error (Error)
#            6 - Fatal
#
#        Flags :
#            0  - None
#            1  - Prefixe horodatage
#            2  - Prefixe level of log
#            4  - Prefixe type of filtre
#            8  - Ajoute horodatage to the name of file (YYYY-MM-DD_HH-MM-SS, Type=2)
#            16 - Save of file existing before ecrasement (Mode=w)
#
#        Couleurs (optionnel1 if Type=Console) :
#            Format: "fatal error warn info debug trace"
#            0-BLACK/1-RED/2-GREEN/3-BROWN/4-BLUE/5-MAGENTA/6-CYAN/7-GREY
#            8-YELLOW/9-LRED/10-LGREEN/11-LBLUE/12-LMAGENTA/13-LCYAN/14-WHITE
#
#        File (optionnel1 if Type=File) : Name of file ("%s" for files dynamiques)
#        Mode   (optionnel2 if Type=File) : a=Ajout, w=Ecrasement
#        TailleMax (optionnel3 if Type=File) : Taille max en octets (max 4 Go, 0=illimite)
#

Appender.Console=1,3,0
Appender.Server=2,2,0,Server.log,w
Appender.GM=2,2,15,gm/gm_%s.log
Appender.DBErrors=2,2,0,DBErrors.log

#  Configuration the Loggers (quoi journaliser) :
#    Logger.name
#        Format: NivwaterLog,ListeAppenders
#
#        NivwaterLog : 0=Disabled, 1=Trace, 2=Debug, 3=Info, 4=Warn, 5=Error, 6=Fatal
#        ListeAppenders : Appenders lies a this logger (separateur : space)
#

Logger.root=5,Console Server
Logger.server=3,Console Server
Logger.commands.gm=3,Console GM
Logger.scripts.hotswap=3,Console Server
Logger.sql.sql=5,Console DBErrors
Logger.sql.updates=3,Console Server
Logger.mmaps=3,Server


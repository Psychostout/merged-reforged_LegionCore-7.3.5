###################################################
# LegionCore worldserver configuration file #
###################################################
[worldserver]

###################################################################################################
# GAME VERSION
#
#    Game.Build.Version
#        Supported WoW Legion 7.3.5 client version.
#        Must be identical in bnetserver.conf and worldserver.conf.
#
#        Available builds: 26124, 26365, 26654, 26822, 26899, 26972
#        Default: 26124

Game.Build.Version = 26972

#
#    Game.Patch
#        Limit available content up to a given patch.
#        Combine with SQL files from the sql/optional folder.
#        Default:     3 - (All 7.3.5 content available)
#                     2 - (7.2.* content available, 7.3+ blocked)
#                     1 - (7.1.* content available, 7.2+ blocked)

Game.Patch = 3

#
###################################################################################################

###################################################################################################
# CONNECTIONS AND DIRECTORIES
#
#    RealmID
#        ID of the realm using this configuration.
#        Important: Must match the entry in the realmlist table of the auth database.
#        Default: 1

RealmID = 1

#
#    DataDir
#        Directory the data extraites of client (maps, vmaps, mmaps, dbc).
#        Important: Must be quoted if the path contains spaces.
#        Example:   "C:/LegionCore/ClientData"
#        Default:    "./ClientData"

DataDir = "./ClientData"

#
#    LogsDir
#        Directory the files of logs.
#        Important: The folder must exist, otherwise log files will not be created.
#        Default:    "./Data/Logs"

LogsDir = "./Data/Logs"

#
#    LoginDatabaseInfo
#    CharacterDatabaseInfo
#    HotfixDatabaseInfo
#    WorldDatabaseInfo
#        Parameters of connection to the bases of data MySQL.
#        Format:  "hostname;port;utilisateur;mot_de_passe;base_de_donnees"
#        Example: ".;somenumber;user;pass;db" - (Pipes named under Windows,
#                   ajouter "enable-named-pipe" in [mysqld] of my.ini)
#
#        Default: "127.0.0.1;3306;root;admin;auth"       - (LoginDatabaseInfo)
#                 "127.0.0.1;3306;root;admin;characters" - (CharacterDatabaseInfo)
#                 "127.0.0.1;3306;root;admin;hotfixes"   - (HotfixDatabaseInfo)
#                 "127.0.0.1;3306;root;admin;world"      - (WorldDatabaseInfo)

LoginDatabaseInfo     = "127.0.0.1;3306;root;admin;auth"
CharacterDatabaseInfo = "127.0.0.1;3306;root;admin;characters"
HotfixDatabaseInfo    = "127.0.0.1;3306;root;admin;hotfixes"
WorldDatabaseInfo     = "127.0.0.1;3306;root;admin;world"

#
#    LoginDatabase.WorkerThreads
#    CharacterDatabase.WorkerThreads
#    HotfixDatabase.WorkerThreads
#    WorldDatabase.WorkerThreads
#        Number of threads for the queries MySQL asynchrones (differees).
#        Chaque thread creates its propre connection to the server MySQL.
#        Default: 1

LoginDatabase.WorkerThreads     = 1
CharacterDatabase.WorkerThreads = 1
HotfixDatabase.WorkerThreads    = 1
WorldDatabase.WorkerThreads     = 1

#
#    LoginDatabase.SynchThreads
#    CharacterDatabase.SynchThreads
#    HotfixDatabase.SynchThreads
#    WorldDatabase.SynchThreads
#        Number of connections MySQL for the queries synchrones (bloquantes).
#        Default: 1

LoginDatabase.SynchThreads     = 1
CharacterDatabase.SynchThreads = 1
HotfixDatabase.SynchThreads    = 1
WorldDatabase.SynchThreads     = 1

#
#    MaxPingTime
#        Interval (in minutes) between the pings of maintien of connection MySQL.
#        Default: 30

MaxPingTime = 30

#
#    WorldServerPort
#        Port TCP principal of server world.
#        Default: 8085

WorldServerPort = 8085

#
#    InstanceServerPort
#        Port TCP for the second world connection (instances).
#        Default: 8086

InstanceServerPort = 8086

#
#    BnetServer.Address
#        Address IP of server Battle.net auquel se connecter.
#        Default: 127.0.0.1

BnetServer.Address = 127.0.0.1

#
#    BnetServer.Port
#        Port of server Battle.net.
#        Default: 1118

BnetServer.Port = 1118

#
#    BindIP
#        Address IP of ecoute of server world.
#        Default: "0.0.0.0" - (Ecoute on all the interfaces)

BindIP = "0.0.0.0"

#
#    ThreadPool
#        Number of threads for the global pool. Used for :
#        - Gestion the signaux
#        - Acces distant (RA)
#        - Ping keep-alive of the base of data
#        - Detection of freeze of core
#        - Network (sockets world)
#        Default: 2

ThreadPool = 2

#
#    SourceDirectory
#        Path to the LegionCore source directory.
#        If empty, the compiled CMAKE_SOURCE_DIR path is used.
#        Default: ""

SourceDirectory = ""

#
#    MySQLExecutable
#        Path to the mysql command-line executable.
#        Used for the application automatique the updates a day SQL.
#        If empty, the path compiled by cmake is used.
#        Example: "C:/Program Files/MySQL/MySQL Server 8.4/bin/mysql.exe"
#        Default:  ""

MySQLExecutable = ""

#
###################################################################################################

###################################################################################################
# SERVER SETTINGS
#
#    GameType
#        Realm type.
#        Default: 0  - (NORMAL)
#                 1  - (PVP)
#                 6  - (RP)
#                 8  - (RPPVP)
#                 16 - (FFA_PVP, PvP libre anywhere sauf zones of repos and sanctuaires)

GameType = 0

#
#    RealmZone
#        Zone geographique of realm. Defines the alphabet allow for the names.
#        Default: 1  - (Developpement - all the langues)
#                 2  - (Etats-Unis    - Latin etendu)
#                 8  - (Anglais       - Latin etendu)
#                 9  - (Allemand      - Latin etendu)
#                 10 - (Francais      - Latin etendu)
#                 11 - (Espagnol      - Latin etendu)
#                 12 - (Russe         - Cyrillique)

RealmZone = 1

#
#    StrictPlayerNames
#        Restreint the names of players to the jeu of characters of the language of server.
#        Prevent creation and force a rename if forbidden characters are used.
#        Default: 0 - (Disabled, client-side check based on timezone)
#                 1 - (Enabled, characters latins of base only)
#                 2 - (Enabled, based on realm zone, see RealmZone)
#                 3 - (Enabled, latins of base + zone of realm)

StrictPlayerNames = 1

#
#    StrictCharterNames
#        Restreint the names of charters of guild to the jeu of characters of the language.
#        Default: 0 - (Disabled)
#                 1 - (Caracteres latins of base only)
#                 2 - (Follows realm zone)
#                 3 - (Latins of base + zone of realm)

StrictCharterNames = 1

#
#    StrictPetNames
#        Restreint the names of pets to the jeu of characters of the language.
#        Default: 0 - (Disabled)
#                 1 - (Caracteres latins of base only)
#                 2 - (Follows realm zone)
#                 3 - (Latins of base + zone of realm)

StrictPetNames = 1

#
#    DBC.Locale
#        Language of DBC/DB2 files used by the server.
#        Default: 0 - (Anglais)
#                 1 - (Coreen)
#                 2 - (Francais)
#                 3 - (Allemand)
#                 4 - (Chinois)
#                 5 - (Taiwanais)
#                 6 - (Espagnol)
#                 7 - (Espagnol Mexique)
#                 8 - (Russe)

DBC.Locale = 0

#
#    DeclinedNames
#        Allow the clients russes a definir the names declines (declinaisons grammaticales).
#        Default: 0 - (Disabled, sauf if RealmZone is russe)
#                 1 - (Enabled)

DeclinedNames = 0

#
#    Expansion
#        Maximum expansion supported by the server.
#        Controle the maps, races and classes available.
#        Default: 6 - (Legion)
#                 5 - (Warlords of Draenor)
#                 4 - (Mists of Pandaria)
#                 3 - (Cataclysm)
#                 2 - (Wrath of the Lich King)
#                 1 - (Burning Crusade)
#                 0 - (Classic, ignores all expansion content)

Expansion = 6

#
#    MinPlayerName
#        Minimum length for names of players.
#        Range: 1-12
#        Default: 2

MinPlayerName = 2

#
#    MinCharterName
#        Minimum length for names of charters of guild.
#        Range: 1-24
#        Default: 2

MinCharterName = 2

#
#    MinPetName
#        Minimum length for names of pets.
#        Range: 1-12
#        Default: 2

MinPetName = 2

#
#    MaxWhoListReturns
#        Maximum players displayed in the /who list.
#        Default: 49

MaxWhoListReturns = 49

#
#    CharactersPerAccount
#        Maximum characters per account across all realms.
#        Important: Must be >= CharactersPerRealm.
#        Default: 50

CharactersPerAccount = 50

#
#    CharactersPerRealm
#        Maximum characters per account on this realm.
#        Range: 1-12
#        Default: 12 - (Client limit)

CharactersPerRealm = 12

#
#    DemonHuntersPerRealm
#        Maximum Demon Hunters per account on this realm.
#        Range: 1-12
#        Default: 1

DemonHuntersPerRealm = 12

#
#    CharacterCreating.MinLevelForDemonHunter
#        Minimum level of an existing character on the account to create
#        a Demon Hunter.
#        Default: 70 - (Requires a character level 70)
#                 0  - (None restriction)

CharacterCreating.MinLevelForDemonHunter = 0

#
#    SkipCinematics
#        Disable the intro cinematic on first login.
#        Utile if the coordonnees of depart are personnalisees.
#        Default: 0 - (Show the intro for chaque new character)
#                 1 - (Show the intro only for le first character of this race)
#                 2 - (Disabled the intro for all the classes)

SkipCinematics = 0

#
#    MaxPlayerLevel
#        Level maximum atteignable by the players.
#        Range: 1-255
#        Default: 110

MaxPlayerLevel = 110

#
#    StartPlayerLevel
#        Level of depart the new characters.
#        Range: 1-MaxPlayerLevel
#        Default: 1

StartPlayerLevel = 1

#
#    StartHeroicPlayerLevel
#        Level of depart the classes heroiques (Chevalier of the Death).
#        Range: 1-MaxPlayerLevel
#        Default: 55

StartHeroicPlayerLevel = 55

#
#    StartPlayerMoney
#        Amount of money (in copper) a character starts with on creation.
#        Default: 0
#                 100 - (1 piece of argent)

StartPlayerMoney = 0

#
#    InstantLogout
#        Security level required for instant logout anywhere.
#        Ne fonctionne pas en combat, en duel ou en chute.
#        Default: 1 - (Moderateurs/GMs/Admins)
#                 0 - (Everyone)
#                 2 - (GMs/Admins)
#                 3 - (Admins only)
#                 4 - (Disabled, personne)

InstantLogout = 0

#
#    NoResetTalentsCost
#        Reset the talents gratuit (without cout en or).
#        Note: In Legion talents are free by default anyway.
#        Default: 0 - (Disabled, cout normal)
#                 1 - (Enabled, gratuit)

NoResetTalentsCost = 1

#
#    PlayerDump.DisallowPaths
#        Forbid the utilisation of chemins in the files of sortie PlayerDump.
#        Securite : emfishing the ecriture in the directories arbitraires.
#        Default: 1

PlayerDump.DisallowPaths = 1

#
#    PlayerDump.DisallowOverwrite
#        Forbid the ecrasement of files existings by PlayerDump.
#        Default: 1

PlayerDump.DisallowOverwrite = 1

#
#    DisableWaterBreath
#        Security level required for breathing underwater.
#        Default: 4 - (Disabled for all)
#                 0 - (Enabled for everyone)
#                 1 - (Moderateurs/GMs/Admins)
#                 2 - (GMs/Admins)
#                 3 - (Admins only)

DisableWaterBreath = 1

#
#    FastFishing
#        Speed up fishing or remove the wait entirely.
#        Default: 0 - (Normal)
#                 1 - (Plus rapide)
#                 2 - (Instantane)

FastFishing = 0

#
#    PlayerStart.AllReputation
#        The new characters commencent with la plupart the reputations
#        haut level required for the items, mounts, etc.
#        Default: 0 - (Disabled)
#                 1 - (Enabled)

PlayerStart.AllReputation = 0

#
#    DungeonFinder.DebugJoin
#        Allow the utilisation of Recherche of Dungeon with 1 seul player.
#        Utile for le developpement/test, pas recommande en production.
#        Default: 0 - (Disabled)
#                 1 - (Enabled)

DungeonFinder.DebugJoin = 1

#
#    Bpay.Enabled
#        Enabled le bouton of the boutique en jeu (BattlePay).
#        Requires the data in la table battlepay.
#        Default: 0 - (Disabled)
#                 1 - (Enabled)

Bpay.Enabled = 1

#
#    BattlePay.CurrencyID
#        Symbole of monnaie show in la boutique en jeu.
#        Default: 4 - (EUR, €)
#                 1 - (USD, $)
#                 2 - (GBP, £)
#                 3 - (KRW, ₩)
#
BattlePay.CurrencyID = 4

#
#    CharacterBoost.Enabled
#        Enabled le Boost of Character depuis la boutique BattlePay.
#        Allow to the players of acheter the boosts level 90/100/110.
#        Default: 1 - (Enabled)
#                 0 - (Disabled)

CharacterBoost.Enabled = 1

#
#    ClassTrial.Enabled
#        Enabled le bouton Essai of Classe a the ecran of selection of character.
#        Creates a character temporaire level 100 which sera locked
#        after disconnection tant qu'a Boost notest pas achete.
#        Default: 1 - (Enabled)
#                 0 - (Disabled)

ClassTrial.Enabled = 1

#
#    CharacterTemplate.Enabled
#        Enabled the modeles of characters a the ecran of creation.
#        Quand enabled, all the modeles defined in character_template
#        are available. The players can create the characters
#        pre-equipes a the levels predefinis (90, 100, 110, etc.).
#        Default: 0 - (Disabled)
#                 1 - (Enabled)

CharacterTemplate.Enabled = 0

#
#    WowToken.Enabled
#        Enable the system WoW Token in the auction house.
#        Allow to the players of acheter/vendre the tokens and de
#        the echanger contre of solde BattlePay.
#        Default: 1 - (Enabled)
#                 0 - (Disabled)

WowToken.Enabled = 0

#
#    WowToken.MarketPrice
#        Price of WoW Token en pieces of or.
#        Default: 60000

WowToken.MarketPrice = 60000

#
#    WowToken.RedeemBalanceAmount
#        Montant of solde BattlePay ajoute lors of rachat of a token.
#        Default: 50

WowToken.RedeemBalanceAmount = 1000

#
#    WowToken.ItemId
#        ID of the item WoW Token in la base of data.
#        Default: 122284

WowToken.ItemId = 122284

#
#    Custom.GainHonorOnGuardKill
#        Gain of honor en tuant a garde of ville.
#        Note: Seuls the gardes the capitales and large villes
#        are marques like donnant of the honor in la base of data.
#        Default: 0 - (Pas of honor)
#                 1 - (Gain of honor)

Custom.GainHonorOnGuardKill = 1

#
#    Custom.GainHonorOnEliteKill
#        Gain of honor en tuant a creature elite (hors rares non-elite).
#        Default: 0 - (Pas of honor)
#                 1 - (Gain of honor)

Custom.GainHonorOnEliteKill = 1

#
#    Player.ControlGuardianPets
#        The pets temporaires non-controles (ex: Dire Beast) attaqueront
#        automatically la cible of player quand il change of cible.
#        Default: 1 - (Enabled)
#                 0 - (Disabled)

Player.ControlGuardianPets = 1

#
#    Player.UnlimitedLegionLegendaries
#        Removed la limit of equipement of legendaires Legion.
#        Allow of equiper a number illimite of legendaires simultanement.
#        Default: 0 - (Disabled, limit blizzlike of 2)
#                 1 - (Enabled, illimite)

Player.UnlimitedLegionLegendaries = 1

#
#    DisableRestart
#        Disabled le restart automatique quotidien of server.
#        Default: 1 - (Restart auto disabled)
#                 0 - (Restart auto chaque day)

DisableRestart = 1

#
#    WorldQuest
#        Enabled/Disabled the system of Quests Mondiales.
#        Default: 1 - (Enabled)
#                 0 - (Disabled)

WorldQuest = 1

#
#    AllFlightPaths
#        Le character connait all the points of flight (deux factions) the the creation.
#        Default: 0 - (Disabled)
#                 1 - (Enabled)

AllFlightPaths = 0

#
#    InstantFlightPaths
#        The flights via the maitres of flight are instantanes (teleportation to the lieu of flight).
#        Default: 0 - (Disabled)
#                 1 - (Enabled)

InstantFlightPaths = 0

#
#    Instance.IgnoreLevel
#        Ignore la condition of level for entrer in the instances.
#        Default: 0 - (Disabled, level required)
#                 1 - (Enabled, tout level accepte)

Instance.IgnoreLevel = 1

#
#    Instance.IgnoreRaid
#        Ignore la condition of group of raid for entrer in the raids.
#        Default: 0 - (Disabled, group raid required)
#                 1 - (Enabled, entree solo possible)

Instance.IgnoreRaid = 1

#
#    Quests.LowLevelHideDiff
#        Difference of level between le player and la quest a partir of laquelle
#        the quests of bas level ne are plus displayed (pas of point of exclamation).
#        Default: 4  - (Masque the quests of 4 levels ou plus en dessous)
#                 -1 - (Disabled, show all the quests)

Quests.LowLevelHideDiff = -1

#
#    Quests.HighLevelHideDiff
#        Difference of level between le player and la quest a partir of laquelle
#        the quests of haut level ne are plus displayed.
#        Default: 7  - (Masque the quests of 7 levels ou plus to the dessus)
#                 -1 - (Disabled, show all the quests)

Quests.HighLevelHideDiff = -1

#
#    Quests.IgnoreRaid
#        Allow of valider the quests non-raid en etant in a group of raid.
#        Default: 0 - (Disabled)
#                 1 - (Enabled)

Quests.IgnoreRaid = 0

#
#    Quests.IgnoreAutoAccept
#        Ignore le flag of acceptation automatique the quests.
#        The players devront accepter manually all the quests.
#        Default: 0 - (Disabled, the values DB appliquent)
#                 1 - (Enabled, acceptation manuelle obligatoire)

Quests.IgnoreAutoAccept = 0

#
#    Quests.IgnoreAutoComplete
#        Ignore le flag of completion automatique the quests.
#        The players devront rendre manually all the quests.
#        Default: 0 - (Disabled, the values DB appliquent)
#                 1 - (Enabled, rendu manuel obligatoire)

Quests.IgnoreAutoComplete = 0

#
#    MaxPrimaryTradeSkill
#        Maximum professions principaux per character.
#        Range: 0-10
#        Default: 2

MaxPrimaryTradeSkill = 2

#
#    MinPetitionSigns
#        Number of signatures required on a charter to create a guild.
#        Range: 0-4
#        Default: 4

MinPetitionSigns = 0

#
#    MailDeliveryDelay
#        Delai (in seconds) of livraison of mail contenant the items.
#        Default: 3600 - (1 hour)

MailDeliveryDelay = 3600

#
#    ClientCacheVersion
#        Version of cache client for forcer a reset of cache cote client.
#        Use a value differente of the one en DB for forcer la reset.
#        Default: 0 - (Used la value of world DB db_version.cache_id)

ClientCacheVersion = 0

#
#    HotfixCacheVersion
#        Version of cache hotfix for forcer a reset of cache hotfix cote client.
#        Default: 0 - (Used la value of world DB version.hotfix_id)

HotfixCacheVersion = 0

#
#    Event.Announce
#        Annonce the evenements saisonniers in le chat lors of their activation.
#        Default: 0 - (Disabled)
#                 1 - (Enabled)

Event.Announce = 0

#
#    BeepAtStart
#        Emet a bip sonore quand le server a fini of start (Linux/Unix).
#        Default: 1 - (Enabled)
#                 0 - (Disabled)

BeepAtStart = 1

#
#    PlayerStart.String
#        Message show on first login of a new character.
#        Default: "" - (Disabled)

PlayerStart.String = ""

#
#    Motd
#        Message of day, show a chaque connection of a player.
#        Use '@' for a retour a la line.
#        Echapper the characters speciaux with '\'.
#        Example: "Bienvenue on le server of Jean@Bonne aventure !"
#        Default:  "Welcome to a Trinity Core server."

Motd = "Welcome to a LegionCore Server."

#
#    Server.LoginInfo
#        Show the informations of version of core (.server info) a la connection.
#        Default: 0 - (Disabled)
#                 1 - (Enabled)

Server.LoginInfo = 0

#
#    Command.LookupMaxResults
#        Maximum resultats displayed by the commandes .lookup.
#        Default: 0 - (Illimite)

Command.LookupMaxResults = 1000

#
#    AllowTickets
#        Allow/forbid the send of new tickets of support.
#        Default: 1 - (Allowed)
#                 0 - (Forbidden)

AllowTickets = 1

#
#    DBC.EnforceItemAttributes
#        Force the utilisation the attributs of items depuis the files DBC
#        to the lieu of ceux of the base of data.
#        Default: 1 - (Enabled, DBC prioritaire)
#                 0 - (Disabled, values DB prioritaires)

DBC.EnforceItemAttributes = 1

#
#    AccountInstancesPerHour
#        Maximum instances differentes qu'a player can entrer per hour.
#        Anti-farm : limit le number of reset of instances.
#        Default: 5

AccountInstancesPerHour = 255

#
#    MaxAccountsOnline
#        Maximum accounts connectes simultanement.
#        The connections additional are placees en file of wait.
#        Default: 1000

MaxAccountsOnline = 1000

#
###################################################################################################

###################################################################################################
# GUILD SETTINGS
#
#    Guild.LevelingEnabled
#        Enable the system of levels of guild.
#        Default: 1 - (Enabled)

Guild.LevelingEnabled = 1

#
#    Guild.SaveInterval
#        Interval (in minutes) between the saves of experience of guild.
#        Default: 15

Guild.SaveInterval = 15

#
#    Guild.UndeletableLevel
#        The guilds atteignant this level (ou plus) ne can plus be dissoutes.
#        Default: 4

Guild.UndeletableLevel = 4

#
#    Guild.XPModifier
#        Multiplier of experience of guild gagnee via the quests.
#        Default: 0.25

Guild.XPModifier = 0.25

#
#    Guild.DailyXPCap
#        Plafond of experience of guild gagne per day.
#        Default: 7807500

Guild.DailyXPCap = 7807500

#
#    Guild.WeeklyReputationCap
#        Plafond of reputation of guild qu'a player can gagner per week.
#        Default: 4375

Guild.WeeklyReputationCap = 4375

#
###################################################################################################

###################################################################################################
# CURRENCY SETTINGS
#
#    Currency.ResetInterval
#        Interval (en days) of reset the compteurs hebdomadaires of monnaies.
#        Default: 7 - (Hebdomadaire)

Currency.ResetInterval = 7

#
#    Currency.ResetHour
#        Hour of day ou the compteurs hebdomadaires are reinitialises (0-23).
#        Default: 6

Currency.ResetHour = 6

#
###################################################################################################

###################################################################################################
# CROSS-FACTION INTERACTION
#
#    AllowTwoSide.Accounts
#        Allow the creation of characters the deux factions on le same account.
#        Default: 1 - (Allowed)
#                 0 - (Forbidden)

AllowTwoSide.Accounts = 1

#
#    AllowTwoSide.Interaction.Calendar
#        Allow the invitations of calendrier between factions.
#        Default: 0 - (Forbidden)

AllowTwoSide.Interaction.Calendar = 0

#
#    AllowTwoSide.Interaction.Chat
#        Allow le chat /dire between factions.
#        Default: 0 - (Forbidden)

AllowTwoSide.Interaction.Chat = 0

#
#    AllowTwoSide.Interaction.Channel
#        Allow the canaux of discussion between factions.
#        Default: 0 - (Forbidden)

AllowTwoSide.Interaction.Channel = 0

#
#    AllowTwoSide.Interaction.Group
#        Allow the groups between factions.
#        Default: 0 - (Forbidden)

AllowTwoSide.Interaction.Group = 0

#
#    AllowTwoSide.Interaction.Guild
#        Allow the guilds mixtes between factions.
#        Default: 0 - (Forbidden)

AllowTwoSide.Interaction.Guild = 0

#
#    AllowTwoSide.Interaction.Auction
#        Allow the auctions between factions (shared auction house).
#        Default: 0 - (Forbidden)

AllowTwoSide.Interaction.Auction = 0

#
#    AllowTwoSide.Interaction.Mail
#        Allow the send of mail between factions.
#        Default: 0 - (Forbidden)

AllowTwoSide.Interaction.Mail = 0

#
#    AllowTwoSide.WhoList
#        Show the characters the deux factions in the /who list.
#        Default: 0 - (Forbidden)

AllowTwoSide.WhoList = 0

#
#    AllowTwoSide.AddFriend
#        Allow the ajout of amis of the faction adverse.
#        Default: 0 - (Forbidden)

AllowTwoSide.AddFriend = 0

#
#    AllowTwoSide.Trade
#        Allow the echange between factions.
#        Default: 0 - (Forbidden)

AllowTwoSide.Trade = 0

#
#    TalentsInspecting
#        Allow the inspection the characters of the faction adverse.
#        N'affecte pas the characters en mode maitre of jeu.
#        Default: 1 - (Allowed)
#                 0 - (Forbidden)

TalentsInspecting = 1

#
###################################################################################################

###################################################################################################
# CREATURE SETTINGS
#
#    ThreatRadius
#        Distance (yards) to the-dela of laquelle a creature evade after avoir ete
#        attiree loin of its point of combat initial.
#        Si inferieur to the rayon of aggro, le rayon of aggro is used.
#        Default: 60

ThreatRadius = 60

#
#    Rate.Creature.Aggro
#        Multiplier of rayon of aggro the creatures.
#        Default: 1   - (100%)
#                 1.5 - (150%)
#                 0   - (Disabled)

Rate.Creature.Aggro = 1

#
#    CreatureFamilyFleeAssistanceRadius
#        Distance (yards) in laquelle a creature en fuite cherche of the aide.
